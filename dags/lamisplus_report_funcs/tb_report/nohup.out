COALESCE(NULLIF(data->'tptMonitoring'->>'tbType',''), NULLIF(data->'tbIptScreening'->>'tbType','')) AS tbTreatmentType,
NULLIF(CAST(NULLIF(data->'tbIptScreening'->>'dateSpecimenSent', '') AS DATE), NULL) AS specimenSentDate,
data->'tbIptScreening'->>'specimenType' AS specimenType,
data->'tbIptScreening'->>'clinicallyEvaulated' as clinicallyEvaulated,
data->'tbIptScreening'->>'chestXrayResultTest' AS chestXrayResultTest,
NULLIF(CAST(NULLIF(data->'tbIptScreening'->>'dateOfChestXrayResultTestDone' , '') AS DATE), NULL) AS dateOfChestXrayResultTestDone,
data->'tptMonitoring'->>'contractionForTpt' AS contractionForTpt,
data->'tbIptScreening'->>'status' as screeningStatus,
TRIM(BOTH ',' FROM
COALESCE(CASE WHEN (data->'tptMonitoring'->>'liverSymptoms' IS NOT NULL AND data->'tptMonitoring'->>'liverSymptoms' != '' AND data->'tptMonitoring'->>'liverSymptoms' != 'No') THEN ',Liver Symptoms' ELSE '' END ||
CASE WHEN (data->'tptMonitoring'->>'chronicAlcohol' IS NOT NULL AND data->'tptMonitoring'->>'chronicAlcohol' != '' AND data->'tptMonitoring'->>'chronicAlcohol' != 'No') THEN ',Chronic Alcohol' ELSE '' END ||
CASE WHEN (data->'tptMonitoring'->>'neurologicSymptoms' IS NOT NULL AND data->'tptMonitoring'->>'neurologicSymptoms' != '' AND data->'tptMonitoring'->>'neurologicSymptoms' != 'No') THEN ',Neurologic Symptoms' ELSE '' END ||
CASE WHEN (data->'tptMonitoring'->>'rash' IS NOT NULL AND data->'tptMonitoring'->>'rash' != '' AND data->'tptMonitoring'->>'rash' != 'No') THEN ',Rash' ELSE '' END,'')) AS contractionOptions,
data->'tbIptScreening'->>'dateOfDiagnosticTest' as dateOfDiagnosticTest, 
data->'tbIptScreening'->>'tbScreeningType' AS tbScreeningType, ROW_NUMBER() OVER (PARTITION BY person_uuid ORDER BY date_of_observation DESC) as rnk3
FROM public."hiv_observation_GxSUmojRHpC"
WHERE archived = 0 
AND
((data->'tbIptScreening'->>'status' LIKE '%Presumptive TB' or data->'tbIptScreening'->>'status' = 'No signs or symptoms of TB')
and (data->'tbIptScreening'->>'outcome' = 'Presumptive TB' or data->'tbIptScreening'->>'outcome'='Not Presumptive')
))subTc WHERE rnk3 = 1
),
tb_completion AS (
SELECT person_uuid AS person_uuid,ods_datim_id,
NULLIF(CAST(NULLIF(data->'tbIptScreening'->>'completionDate', '') AS DATE), NULL)AS completionDate,
data->'tbIptScreening'->>'treatmentOutcome' AS treatmentOutcome
FROM public."hiv_observation_GxSUmojRHpC"
WHERE
(data->'tbIptScreening'->>'completionDate' IS NOT NULL AND data->'tbIptScreening'->>'completionDate' != '') AND
(data->'tbIptScreening'->>'treatmentOutcome' IS NOT NULL AND data->'tbIptScreening'->>'treatmentOutcome' != '')
AND archived =0
)
SELECT COALESCE(ts.person_uuid, tc.person_uuid) AS person_uuid_tb,-- Use COALESCE to get the person_uuid from either table
COALESCE(ts.ods_datim_id, tc.ods_datim_id) AS ods_datim_id,
ts.tbTreatmentStartDate,COALESCE(ts.tbDiagnosticResult,ts.chestXrayResult) as tbDiagnosticResult,
ts.tbDiagnosticTestType,ts.tbScreeningType,ts.screeningStatus,ts.tbTreatmentType,
ts.screeningDate,ts.specimenSentDate,ts.specimenType,ts.clinicallyEvaulated,
ts.chestXrayResultTest,ts.dateOfChestXrayResultTestDone,ts.contractionForTpt,
ts.contractionOptions,dateOfDiagnosticTest,tc.completionDate,tc.treatmentOutcome
FROM tb_start ts
FULL OUTER JOIN tb_completion tc
ON ts.person_uuid = tc.person_uuid AND ts.ods_datim_id = tc.ods_datim_id"
PL/pgSQL function tb.proc_tbtreatmentnew(character varying) line 24 at EXECUTE
]
